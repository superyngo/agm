editor = ""

[central]
prompt_source = "~/.local/share/agm/prompts/MASTER.md"
skills_source = "~/.local/share/agm/skills"
source_dir = "~/.local/share/agm/source"
skill_repos = []
files_base = "~/.local/share/agm/files"
files = []

[tools.claude]
name = "Claude Code"
config_dir = "~/.claude"
settings = [
    "~/.claude.json",
    "settings.json",
    "settings.local.json",
]
auth = [".credentials.json"]
prompt_filename = "CLAUDE.md"
skills_dir = "skills"
mcp = ["settings.json"]
files = []

[tools.copilot]
name = "Copilot CLI"
config_dir = "~/.copilot"
settings = ["config.json"]
auth = ["config.json"]
prompt_filename = "AGENTS.md"
skills_dir = "skills"
mcp = ["mcp-config.json"]
files = []

[tools.gemini]
name = "Gemini CLI"
config_dir = "~/.gemini"
settings = ["settings.json"]
auth = [
    "oauth_creds.json",
    "accounts.json",
    "google_accounts.json",
]
prompt_filename = "GEMINI.md"
skills_dir = "skills"
mcp = ["settings.json"]
files = []

[tools.opencode]
name = "OpenCode"
config_dir = "~/.config/opencode"
settings = ["opencode.json"]
auth = ["~/.local/share/opencode/auth.json"]
prompt_filename = "AGENTS.md"
skills_dir = "skills"
mcp = ["opencode.json"]
files = []
